# Copy to .env only when you want to override these safe local-development defaults.
SERVICE_VERSION=0.1.0
IMAGE_TAG=dev
LOG_LEVEL=INFO
MESSAGE_SCHEMA_VERSION=1.0

# PostgreSQL (local development only; choose a strong password outside local use)
POSTGRES_DB=har_db
POSTGRES_USER=har_user
POSTGRES_PASSWORD=har_dev_password
POSTGRES_PORT=5432
# Used when backend services run directly on the host. Compose constructs its
# container-internal URL from the POSTGRES_* values above.
DATABASE_URL=postgresql://har_user:har_dev_password@localhost:5432/har_db

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883

# Public service ports
HOST_BIND_ADDRESS=127.0.0.1
FUSION_SERVICE_PORT=8001
FEEDBACK_SERVICE_PORT=8002
SENSOR_SERVICE_PORT=8003
VIDEO_SERVICE_PORT=8004
DASHBOARD_PORT=5173

# Sensor service
WINDOW_SIZE=128
WINDOW_OVERLAP=0.5
SENSOR_MODEL_ID=
SENSOR_MODEL_REVISION=69f07d89b9520c9ab4424fafed6d079c3d12b26d
# Optional local .tflite artifact; the service never downloads models at runtime.
# In Compose, put the file under data/models and use /models/<filename>.tflite.
SENSOR_MODEL_PATH=
# Required class order when SENSOR_MODEL_PATH is set, for example:
# SENSOR_MODEL_LABELS=STATIONARY,WALKING,EXERCISING,STAIRS
SENSOR_MODEL_LABELS=
USE_FALLBACK=true
ACCEL_UNIT=g
GYRO_UNIT=rad_s
ACCEL_SCALE=1.0
GYRO_SCALE=1.0
MODEL_INPUT_MEAN=0.0
MODEL_INPUT_STD=1.0
MODEL_SUPPRESS_GRAVITY=true

# Video service
FPS=12
CAMERA_INDEX=0
HORIZONTAL_ANGLE_THRESHOLD=25
MIN_VISIBILITY=0.6
SITTING_JOINT_ANGLE=135
STANDING_JOINT_ANGLE=155
MOTION_HISTORY_LENGTH=12
WALKING_MOTION_THRESHOLD=0.018
EXERCISE_MOTION_THRESHOLD=0.045
RECONNECT_ATTEMPTS=5
RECONNECT_INITIAL_BACKOFF=0.25
RECONNECT_MAX_BACKOFF=5.0
# Linux Compose webcam overlay settings.
VIDEO_DEVICE=/dev/video0
VIDEO_GID=44

# Fusion service
MODALITY_WEIGHTS=sensor=0.5,video=0.5
SMOOTHING_WINDOW=5
FALL_ACCEL_THRESHOLD=2.5
INACTIVITY_SECONDS=1800
FUSION_INTERVAL=1.0

# Feedback service. Milestone 1 defaults to the safe offline template provider.
LLM_PROVIDER=template
LLM_MODEL=llama3.2:3b
OLLAMA_HOST=http://host.docker.internal:11434
FEEDBACK_INTERVAL=300
SUMMARY_SCHEDULE="0 20 * * *"

# Optional cloud credentials must remain empty and must never be committed.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
