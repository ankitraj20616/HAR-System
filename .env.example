# Copy to .env only when you want to override these safe local-development defaults.
SERVICE_VERSION=0.4.0
IMAGE_TAG=dev
LOG_LEVEL=INFO
MESSAGE_SCHEMA_VERSION=1.0

# PostgreSQL (local development only; choose a strong password outside local use)
POSTGRES_DB=har_db
POSTGRES_USER=har_user
POSTGRES_PASSWORD=har_dev_password
POSTGRES_PORT=5432
# Used when backend services run directly on the host. Compose constructs its
# container-internal URL from the POSTGRES_* values above.
DATABASE_URL=postgresql://har_user:har_dev_password@localhost:5432/har_db

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883

# Built-in offline demo simulator (started automatically by Compose)
SIMULATOR_DEVICE_ID=demo-sim-01
SIMULATOR_SAMPLING_HZ=50
SIMULATOR_CHUNK_SECONDS=0.5
SIMULATOR_SCENARIO_SECONDS=12

# Public service ports
HOST_BIND_ADDRESS=127.0.0.1
FUSION_SERVICE_PORT=8001
FEEDBACK_SERVICE_PORT=8002
AUTH_SERVICE_PORT=8005
SENSOR_SERVICE_PORT=8003
VIDEO_SERVICE_PORT=8004
DASHBOARD_PORT=5173

# Supabase Auth + RBAC. The publishable key is safe for the browser; the service
# role key and ticket secret are backend-only and must never use a VITE_ prefix.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ALGORITHMS=RS256,ES256
AUTH_TICKET_SECRET=replace-with-at-least-32-random-characters
AUTH_TICKET_TTL_SECONDS=30
AUTH_UPSTREAM_TIMEOUT_SECONDS=10

# Sensor service
WINDOW_SIZE=128
WINDOW_OVERLAP=0.5
SENSOR_MODEL_ID=STMicroelectronics/IGN-HAR-model
SENSOR_MODEL_REVISION=69f07d89b9520c9ab4424fafed6d079c3d12b26d
# Optional local .tflite artifact; the service never downloads models at runtime.
# In Compose, put the file under data/models and use /models/<filename>.tflite.
SENSOR_MODEL_PATH=
# Required class order when SENSOR_MODEL_PATH is set, for example:
# SENSOR_MODEL_LABELS=STATIONARY,WALKING,EXERCISING,STAIRS
SENSOR_MODEL_LABELS=
USE_FALLBACK=true
ACCEL_UNIT=g
GYRO_UNIT=rad_s
ACCEL_SCALE=1.0
GYRO_SCALE=1.0
MODEL_INPUT_MEAN=0.0
MODEL_INPUT_STD=1.0
MODEL_SUPPRESS_GRAVITY=true

# Video service
FPS=12
CAMERA_INDEX=0
HORIZONTAL_ANGLE_THRESHOLD=25
MIN_VISIBILITY=0.6
SITTING_JOINT_ANGLE=135
STANDING_JOINT_ANGLE=155
MOTION_HISTORY_LENGTH=12
WALKING_MOTION_THRESHOLD=0.018
EXERCISE_MOTION_THRESHOLD=0.045
RECONNECT_ATTEMPTS=5
RECONNECT_INITIAL_BACKOFF=0.25
RECONNECT_MAX_BACKOFF=5.0
# Linux Compose webcam overlay settings.
VIDEO_DEVICE=/dev/video0
VIDEO_GID=44

# Fusion service
MODALITY_WEIGHTS=sensor=0.5,video=0.5
SMOOTHING_WINDOW=5
ALIGNMENT_TOLERANCE_MS=1300
BUFFER_RETENTION_MS=10000
BUFFER_MAX_SIZE=256
STALE_TIMEOUT_SECONDS=3.0
FALL_ACCEL_THRESHOLD=2.5
FALL_CORRELATION_MS=1500
FALL_COOLDOWN_SECONDS=30
FALL_RECOVERY_TIMEOUT_SECONDS=60
INACTIVITY_SECONDS=1800
INACTIVITY_MOTION_THRESHOLD=0.08
ABNORMAL_MIN_SECONDS=3600
ABNORMAL_BASELINE_SAMPLES=5
ABNORMAL_BASELINE_MULTIPLIER=3.0
FUSION_INTERVAL=1.0
WEBSOCKET_QUEUE_SIZE=64
INPUT_QUEUE_SIZE=512
API_MAX_LIMIT=1000

# Feedback service. Ollama runs locally/offline after the selected model is pulled.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
OLLAMA_HOST=http://host.docker.internal:11434
GENERATION_TIMEOUT=30
FEEDBACK_INTERVAL=900
SUMMARY_SCHEDULE="0 20 * * *"
MAXIMUM_DIGEST_SIZE=12000
FEEDBACK_FALLBACK_ENABLED=true
FEEDBACK_MAX_RECOMMENDATIONS=5
FEEDBACK_DEFAULT_PERIOD_HOURS=24
FEEDBACK_API_MAX_PERIOD_DAYS=30
FEEDBACK_INPUT_QUEUE_SIZE=128
FEEDBACK_WEBSOCKET_QUEUE_SIZE=64

# Optional cloud credentials must remain empty and must never be committed.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
