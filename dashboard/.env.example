# Leave blank for same-origin nginx/Vite proxy defaults.
VITE_FUSION_API_BASE=
VITE_FEEDBACK_API_BASE=
# Supabase configuration is loaded at runtime from /api/auth/config. Do not put
# SUPABASE_SERVICE_ROLE_KEY or any other backend secret in this file.
# Direct development alternatives:
# VITE_FUSION_WS_URL=ws://localhost:8001/ws
# VITE_FEEDBACK_WS_URL=ws://localhost:8002/ws
